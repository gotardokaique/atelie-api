package com.gestao.api.config;

import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.web.servlet.config.annotation.CorsRegistry;
import org.springframework.web.servlet.config.annotation.WebMvcConfigurer;

@Configuration
public class WebConfig {

    @Bean
    public WebMvcConfigurer corsConfigurer() {
        return new WebMvcConfigurer() {
            @Override
            public void addCorsMappings(CorsRegistry registry) {
                registry.addMapping("/api/v1/**") // Aplica a configuração para todos endpoints sob /api/v1/
                        .allowedOrigins("http://localhost:3000") // Permite requisições desta origem (seu frontend Next.js)
                        .allowedMethods("GET", "POST", "PUT", "PATCH", "OPTIONS") // Métodos HTTP permitidos
                        .allowedHeaders("*") // Permite todos os headers na requisição
                        .allowCredentials(false); // Mude para true se precisar enviar cookies/autenticação baseada em sessão
                        // .maxAge(3600); // Tempo que o resultado da preflight request pode ser cacheado (em segundos)
            }
        };
    }
}